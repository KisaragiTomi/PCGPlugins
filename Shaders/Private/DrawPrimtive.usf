#include "/Engine/Public/Platform.ush"
#include "/Plugin/PCGPlugins/Shaders/Private/General.usf"

struct FTest
{
	float4 Position : SV_POSITION;
	float2 UV : TEXCOORD0;
};

float4x4 L2WTest;
float4x4 V2P;
float InvHalfCaptureWidth;
float InvHalfCaptureHeight;
float RasterMinDepth;
float RasterInvDepthRange;

void MainVertexShader(float4 InPosition : ATTRIBUTE0, float2 InUV : ATTRIBUTE1, out float2 OutUV : TEXCOORD0, out float4 OutPosition : SV_POSITION)
{
	OutPosition = mul(InPosition , L2WTest);
	// OutPosition = InPosition;
	// OutPosition /= 50;
#if DIPS_Test
	OutPosition.z = 0.50;
#elif DIPS_DRAWHEIGHT
	OutPosition.z = 0.00;
#endif
	
	// OutPosition.z = -.1;
	OutUV = InUV;
}



