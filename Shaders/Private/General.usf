void FillSharedGroup(
    in int3 DispatchThreadId, 
    in int3 GroupThreadId,

    int2 MaxCell,
    in uint GroupIndex
)
{
    // int2 HVCheck = int2(GroupThreadId.x < GENERAL_SHAREGROUP_EXTENT, GroupThreadId.y < GENERAL_SHAREGROUP_EXTENT);
    // HVCheck *= -1;
    // HVCheck += int2(GroupThreadId.x + GENERAL_SHAREGROUP_EXTENT >= THREADGROUPSIZE_X, GroupThreadId.y + GENERAL_SHAREGROUP_EXTENT >= THREADGROUPSIZE_Y);
    // HVCheck *= GENERAL_SHAREGROUP_EXTENT;
    // int2 GroupOffset = HVCheck + GENERAL_SHAREGROUP_EXTENT;
	   //
    // int2 SharePosX = clamp(DispatchThreadId.xy + int2(HVCheck.x, 0), int2(0,0), int2(MaxCell.x - 1, MaxCell.y - 1));
    // int2 SharePosY = clamp(DispatchThreadId.xy + int2(0, HVCheck.y), int2(0,0), int2(MaxCell.x - 1, MaxCell.y - 1));
    // int2 SharePosXY = clamp(DispatchThreadId.xy + HVCheck, int2(0,0), int2(MaxCell.x - 1, MaxCell.y - 1));
    // int2 SharePosCore = DispatchThreadId.xy;
    // // SharePosX = clamp(DispatchThreadId.xy -3, int2(0,0), int2(MaxCell.x - 1, MaxCell.y - 1));
    // // SharePosX.x = max(SharePosX.x, 0);
    // GENERAL_SHAREGROUP_NAME[GroupThreadId.x + GroupOffset.x][GroupThreadId.y + GENERAL_SHAREGROUP_EXTENT] = CREATE_SHARE_DATA_FUNC(SharePosX);
    // GENERAL_SHAREGROUP_NAME[GroupThreadId.x + GENERAL_SHAREGROUP_EXTENT][GroupThreadId.y + GroupOffset.y] = CREATE_SHARE_DATA_FUNC(SharePosY);
    // GENERAL_SHAREGROUP_NAME[GroupThreadId.x + GroupOffset.x][GroupThreadId.y + GroupOffset.y] = CREATE_SHARE_DATA_FUNC(SharePosXY);
    // GENERAL_SHAREGROUP_NAME[GroupThreadId.x + GENERAL_SHAREGROUP_EXTENT][GroupThreadId.y + GENERAL_SHAREGROUP_EXTENT] = CREATE_SHARE_DATA_FUNC(SharePosCore);
    
    int2 groupTopLeftGlobal = DispatchThreadId.xy - GroupThreadId.xy - int2(GENERAL_SHAREGROUP_EXTENT, GENERAL_SHAREGROUP_EXTENT);
    
    const uint THREAD_COUNT = THREADGROUPSIZE_X * THREADGROUPSIZE_Y;
    const uint SHARED_DIM_X = THREADGROUPSIZE_X + 2 * GENERAL_SHAREGROUP_EXTENT;
    const uint SHARED_DIM_Y = THREADGROUPSIZE_Y + 2 * GENERAL_SHAREGROUP_EXTENT;
    const uint TOTAL_SHARED_ELEMENTS = SHARED_DIM_X * SHARED_DIM_Y;
    
    for (uint i = GroupIndex; i < TOTAL_SHARED_ELEMENTS; i += THREAD_COUNT)
    {
        int localX = i % SHARED_DIM_X;
        int localY = i / SHARED_DIM_X;
        
        int2 globalPos = groupTopLeftGlobal + int2(localX, localY);
        globalPos = clamp(globalPos, int2(0,0), MaxCell - 1);
        
        GENERAL_SHAREGROUP_NAME[localX][localY] = CREATE_SHARE_DATA_FUNC(globalPos);
    }
    
    GroupMemoryBarrierWithGroupSync();
}



