float CalOcclusion(Texture2D<float4> SceneDepth, float4x4 TransformNormal, float2 DispatchThreadId, float MaxHeight, float CaptureSize, float RadiusMult)
{
    float Radius = CaptureSize * RadiusMult;
    float MaxCell = 0;
    SceneDepth.GetDimensions(MaxCell, MaxCell);
    float2 UV = DispatchThreadId / MaxCell;
    
    float CurrentDepth = MaxHeight - SceneDepth[int2(UV * MaxCell)].x;
    float SampleCount = 1;
    float Occlusion = 0;
    
    for (int i = 0; i < SampleCount; i++)
    {
        float3 SamplePosition = SphereSamples[i] /  0.1968 ;
        // SamplePosition = normalize(SamplePosition);
        SamplePosition = SamplePosition * Radius;
        float3 CheckPositon = mul(float4(SamplePosition, 0), TransformNormal).xyz;
        int2 SamplePos = DispatchThreadId + CheckPositon.xy / CaptureSize * MaxCell;
        if (SamplePos.x < 0 || SamplePos.y < 0 || SamplePos.x >= MaxCell || SamplePos.y >= MaxCell) continue;
        // int2 SamplePos = (UV + CheckUV) * MaxCell;
        float Height = MaxHeight - SceneDepth[SamplePos].x;
        float RangeCheck = smoothstep(0, 1, Radius / (Height - CurrentDepth - CheckPositon.z));
        RangeCheck *= abs(Height - CurrentDepth) > CaptureSize/100;
        RangeCheck *= Height > 0;
        Occlusion += RangeCheck;
    }
    Occlusion /= SampleCount;
    // Occlusion = Occlusion > .05 ? Occlusion : 0;
    return Occlusion;
}


float3 CalNormal(Texture2D<float4> SceneDepth, uint3 DispatchThreadId, float MaxHeight, float CaptureSize)
{
    float MaxCell;
    SceneDepth.GetDimensions(MaxCell, MaxCell);
    
    MaxCell -= 1;
    
    int2 XYL = clamp(DispatchThreadId.xy + int2(-1, 0), 0, MaxCell);
    int2 XYR = clamp(DispatchThreadId.xy + int2(1, 0), 0, MaxCell);
    int2 XYB = clamp(DispatchThreadId.xy + int2(0, 1), 0, MaxCell);
    int2 XYT = clamp(DispatchThreadId.xy + int2(0, -1), 0, MaxCell);
    
    float HeightL = MaxHeight - SceneDepth[XYL].x;
    float HeightR = MaxHeight - SceneDepth[XYR].x;
    float HeightB = MaxHeight - SceneDepth[XYB].x;
    float HeightT = MaxHeight - SceneDepth[XYT].x;
    // HeightR = 0;
    // HeightL = 0;
    float3 DirDDX = float3((XYR - XYL) / MaxCell * CaptureSize, HeightR - HeightL);
    float3 DirDDY = float3((XYT - XYB) / MaxCell * CaptureSize, HeightT - HeightB);
    
    DirDDX = length(DirDDX) > .001 ? normalize(DirDDX) : float3(0, 0, 1);
    DirDDY = length(DirDDY) > .001 ? normalize(DirDDY) : float3(0, 0, 1);
    float3 Normal = cross(DirDDY, DirDDX); 
    
    return Normal;
    
    // float3 LandscapePositionXN = float3(xNext , j , LandscapeDataAccess::GetLocalHeight(Values[(j- YMin) * XNum + (xNext - XMin)]));
    // float2 LandscapePositionXP = float2(xPrev , j , LandscapeDataAccess::GetLocalHeight(Values[(j- YMin) * XNum + (xPrev - XMin)]));
    // float2 LandscapePositionYN = float2(i , yNext , LandscapeDataAccess::GetLocalHeight(Values[(yNext- YMin) * XNum + (i - XMin)]));
    // float2 LandscapePositionYP = float2(i , yPrev , LandscapeDataAccess::GetLocalHeight(Values[(yPrev- YMin) * XNum + (i - XMin)]));
    // float2 DX = (LandscapePositionXN - LandscapePositionXP).GetSafeNormal();
    // float2 DY = (LandscapePositionYN - LandscapePositionYP).GetSafeNormal();
    // float2 Normal = float2::CrossProduct(DX, DY).GetSafeNormal();
}


// ===== Cubic B-Spline smooth curve =====
// Uniform cubic B-Spline: the curve approximates the control points (does not pass through them), C2-continuous across segments.
// A segment is defined by 4 adjacent control points P0..P3, with t in [0,1] falling between P1 and P2.

float3 BSplinePosition(float3 P0, float3 P1, float3 P2, float3 P3, float t)
{
    float t2 = t * t;
    float t3 = t2 * t;
    float b0 = (-t3 + 3.0 * t2 - 3.0 * t + 1.0) / 6.0;
    float b1 = (3.0 * t3 - 6.0 * t2 + 4.0) / 6.0;
    float b2 = (-3.0 * t3 + 3.0 * t2 + 3.0 * t + 1.0) / 6.0;
    float b3 = t3 / 6.0;
    return b0 * P0 + b1 * P1 + b2 * P2 + b3 * P3;
}

float3 BSplineTangent(float3 P0, float3 P1, float3 P2, float3 P3, float t)
{
    float t2 = t * t;
    float d0 = (-3.0 * t2 + 6.0 * t - 3.0) / 6.0;
    float d1 = (9.0 * t2 - 12.0 * t) / 6.0;
    float d2 = (-9.0 * t2 + 6.0 * t + 3.0) / 6.0;
    float d3 = (3.0 * t2) / 6.0;
    return d0 * P0 + d1 * P1 + d2 * P2 + d3 * P3;
}

// Maps the global parameter a in [0,1] to a segment: NumCtrl control points form NumCtrl-1 segments.
// Outputs SegIndex (the control-point index of P1 for that segment) and the local t within the segment.
void BSplineMapGlobalAlpha(float a, int NumCtrl, out int SegIndex, out float LocalT)
{
    int NumSeg = max(NumCtrl - 1, 1);
    float g = saturate(a) * NumSeg;
    SegIndex = min((int) floor(g), NumSeg - 1);
    LocalT = g - SegIndex;
}

