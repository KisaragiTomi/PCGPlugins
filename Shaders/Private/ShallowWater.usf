[numthreads(THREADGROUPSIZE_X, THREADGROUPSIZE_Y, THREADGROUPSIZE_Z)]
void ShallowWater(
                        uint3 GroupId : SV_GroupID,
                        uint3 DispatchThreadId : SV_DispatchThreadID,
                        uint3 GroupThreadId : SV_GroupThreadID,
                        uint GroupIndex : SV_GroupIndex) 
{
    
#if SW_RESETDISPATCHREGION
	ResetDispatchRegion(DispatchThreadId);
#elif SW_SCANDISPATCHREGION
	ScanDispatchRegion(DispatchThreadId);
#elif SW_FINALIZEDISPATCHREGION
	FinalizeDispatchRegion(DispatchThreadId);
#elif SW_VELOCITYHEIGHTSIM
    CalVelocityHeight_Flux(DispatchThreadId, GroupThreadId, GroupId, GroupIndex);
#elif SW_SHALLOWINTEGRATE
    CalShalllowIntegrate_Flux(DispatchThreadId, GroupThreadId, GroupId, GroupIndex);
#elif SW_RESULT
	CalShalllowWaterResult_Flux(DispatchThreadId, GroupThreadId, GroupId, GroupIndex);
#elif SW_SETHEIGHT
	SetHeight(DispatchThreadId, GroupThreadId, GroupId, GroupIndex);
#elif SW_SMOOTHHEIGHT
	HeightSmooth(DispatchThreadId, GroupThreadId, GroupId, GroupIndex);
#endif
}

